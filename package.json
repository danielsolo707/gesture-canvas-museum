{
  "name": "gesture-canvas-museum",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "copy-mediapipe": "node scripts/copy-mediapipe.mjs",
    "build": "npm run copy-mediapipe && tsc -b && vite build",
    "preview": "vite preview",
    "start": "node scripts/serve-prod.mjs",
    "start:local": "vite preview --host 127.0.0.1 --port 3000",
    "diagnose:camera": "node scripts/diagnose-playwright.mjs http://localhost:3000 18000",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.172.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^20.9.0",
    "playwright": "^1.60.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
